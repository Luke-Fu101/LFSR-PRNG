import random
class LFSR_Class:
    def __init__(self):
        self.Length = 16  # Length of the LFSR
        self.seed = []
        self.feedback_bit = None
        self.output_bit = None
        self.history = []
        self.taps = [0, 2, 3, 5]  # Taps for the LFSR (0-indexed)
        for i in range(self.Length):
            self.seed.append(random.randint(0, 1))
        if sum(self.seed) == 0:  # Guard rail against all-zeros dead state
            self.seed[0] = 1
        print("Initialized state successfully:", self.seed)
    def shift(self):
        self.feedback_bit = 0
        for tap in self.taps:
            self.feedback_bit ^= self.seed[tap]
        self.output_bit = self.seed[-1]
        self.seed.pop()
        self.seed.insert(0, self.feedback_bit)
        self.history.append(self.output_bit)
        return self.output_bit
    def get_bit_self(self):
        return self.output_bit
LFSR = LFSR_Class()
